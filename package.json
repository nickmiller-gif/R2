{
  "name": "r2",
  "version": "1.0.0",
  "description": "R2 is the clean backend/core repository for the revised ecosystem.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:imports": "bash scripts/check-banned-imports.sh",
    "lint:migrations": "bash scripts/check-migrations.sh",
    "lint:supabase:drift": "bash scripts/check-supabase-migration-drift.sh",
    "lint:supabase:types": "bash scripts/check-supabase-generated-types.sh",
    "check": "npm run typecheck && npm run test && npm run lint:imports && npm run lint:migrations && npm run lint:supabase:drift && npm run lint:supabase:types",
    "deploy:widget": "npx wrangler@3 pages deploy apps/eigen-widget --project-name eigen",
    "deploy:widget:list-projects": "npx wrangler@3 pages project list"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickmiller-gif/R2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/nickmiller-gif/R2/issues"
  },
  "homepage": "https://github.com/nickmiller-gif/R2#readme",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@rolldown/pluginutils": "^1.0.0-rc.16",
    "@supabase/supabase-js": "^2.104.0"
  }
}
