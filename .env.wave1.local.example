# Copy to `.env.wave1.local` in this directory (R2 repo root), then fill in values.
# `.env.wave1.local` is gitignored — never commit real secrets.
#
# Values must match Supabase Edge secrets on your project:
#   R2_SIGNAL_INGEST_URL
#   R2_SIGNAL_INGEST_BEARER
#   R2_SIGNAL_INGEST_HMAC_SECRET
#
# Used by: node scripts/stage-wave1-signal-hardening.mjs (run with cwd = this folder)

R2_SIGNAL_INGEST_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/r2-signal-ingest
R2_SIGNAL_INGEST_BEARER=
R2_SIGNAL_INGEST_HMAC_SECRET=
