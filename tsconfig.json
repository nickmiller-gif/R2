{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "src/*": ["./*"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "types/**/*.d.ts",
    "supabase/functions/_shared/retrieval-budget.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
