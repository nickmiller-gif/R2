{
  "name": "r2",
  "version": "1.0.0",
  "description": "R2 is the clean backend/core repository for the revised ecosystem.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"supabase/functions/**/*.ts\" \"tests/**/*.ts\" \"packages/**/*.ts\"",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:imports": "eslint src --max-warnings=0",
    "lint:migrations": "bash scripts/check-migrations.sh",
    "lint:supabase:drift": "bash scripts/check-supabase-migration-drift.sh",
    "lint:supabase:types": "bash scripts/check-supabase-generated-types.sh",
    "lint:correlation": "bash scripts/check-correlation-wrap.sh",
    "lint:eigen-sites": "node scripts/validate-eigen-site-registry.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "verify:post-hardening": "node scripts/post-hardening-prod-verify.mjs",
    "test:edge-authz-contract": "node scripts/edge-authz-contract-test.mjs",
    "verify:kb-four": "node scripts/kb-four-bridge-verify.mjs",
    "check": "npm run typecheck && npm run test && npm run lint && npm run lint:imports && npm run lint:migrations && npm run lint:supabase:drift && npm run lint:supabase:types && npm run lint:correlation && npm run lint:eigen-sites && npm run security:scan"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "database.types.ts": []
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickmiller-gif/R2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/nickmiller-gif/R2/issues"
  },
  "homepage": "https://github.com/nickmiller-gif/R2#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@rolldown/pluginutils": "^1.0.0-rc.18",
    "@supabase/supabase-js": "^2.106.1"
  }
}
