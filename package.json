{
  "name": "r2",
  "version": "1.0.0",
  "description": "R2 is the clean backend/core repository for the revised ecosystem.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"supabase/functions/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:imports": "eslint src --max-warnings=0",
    "lint:migrations": "bash scripts/check-migrations.sh",
    "lint:supabase:drift": "bash scripts/check-supabase-migration-drift.sh",
    "lint:supabase:types": "bash scripts/check-supabase-generated-types.sh",
    "lint:correlation": "bash scripts/check-correlation-wrap.sh",
    "check": "npm run typecheck && npm run test && npm run lint && npm run lint:imports && npm run lint:migrations && npm run lint:supabase:drift && npm run lint:supabase:types && npm run lint:correlation"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "database.types.ts": []
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickmiller-gif/R2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/nickmiller-gif/R2/issues"
  },
  "homepage": "https://github.com/nickmiller-gif/R2#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@rolldown/pluginutils": "^1.0.0-rc.17",
    "@supabase/supabase-js": "^2.104.1"
  }
}
