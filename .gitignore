.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# TypeScript compiled outputs — src/ should only contain .ts sources. Historical
# `.js` / `.d.ts` alongside sources in src/ were stale build artifacts; block
# them here so they cannot be re-committed.
src/**/*.js
src/**/*.d.ts
src/**/*.js.map

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp and cache directory
.temp
.cache

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

