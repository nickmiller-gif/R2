{
  "version": 1,

  // ─── MCP Servers ───────────────────────────────────────────────────────────
  // These are available to Claude Code agents running in CI and locally
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=zudslxucibosjwefojtm&features=docs,account,database,debugging,development,functions,branching,storage",
      "headers": {
        "Authorization": "Bearer ${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    }
  },

  // ─── Allowed Tools ─────────────────────────────────────────────────────────
  // Tools Claude Code is permitted to use without asking for confirmation
  "allowedTools": [
    "Bash",
    "Read",
    "Write",
    "Edit",
    "MultiEdit",
    "Glob",
    "Grep",
    "TodoRead",
    "TodoWrite",
    "WebFetch",
    "WebSearch",
    "mcp__supabase__execute_sql",
    "mcp__supabase__list_tables",
    "mcp__supabase__apply_migration",
    "mcp__supabase__list_migrations",
    "mcp__supabase__list_edge_functions",
    "mcp__supabase__deploy_edge_function",
    "mcp__supabase__get_logs",
    "mcp__supabase__list_branches",
    "mcp__supabase__create_branch",
    "mcp__supabase__merge_branch",
    "mcp__supabase__generate_typescript_types",
    "mcp__github__create_pull_request",
    "mcp__github__list_issues",
    "mcp__github__create_issue",
    "mcp__github__get_pull_request",
    "mcp__github__push_files"
  ],

  // ─── Permissions ───────────────────────────────────────────────────────────
  "permissions": {
    "allow": [
      // File system — full repo access
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",

      // Supabase CLI
      "Bash(supabase:*)",

      // Read/write anywhere in the repo
      "Read(**)",
      "Write(**)",
      "Edit(**)"
    ],
    "deny": [
      // Never delete the database
      "mcp__supabase__delete_project",
      "mcp__supabase__pause_project",

      // Never touch production secrets
      "Bash(rm -rf *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ]
  },

  // ─── Agent Behavior ────────────────────────────────────────────────────────
  "agent": {
    // Cap autonomous turns to prevent runaway loops
    "maxTurns": 20,

    // Always create a branch for changes rather than committing to main
    "preferBranch": true,

    // Post a summary comment on the PR/issue when done
    "postSummary": true
  }
}
